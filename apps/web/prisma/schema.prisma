generator client {
  provider = "prisma-client"
  output   = "../src/infrastructure/database/generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String?
  image        String?
  results      Result[]
  questionAttempts QuestionAttempt[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model Subject {
  id              String              @id @default(cuid())
  name            String              @unique
  slug            String              @unique
  description     String?
  sourceDocuments SourceDocument[]
  generationCaches GeneratedQuizCache[]
  quizzes         Quiz[]
  questionAttempts QuestionAttempt[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@map("subjects")
}

model Quiz {
  id              String             @id @default(cuid())
  subjectId       String
  subject         Subject            @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  difficulty      String             @default("intermediate")
  totalQuestions  Int                @default(10)
  generationModel String?
  generationStatus String            @default("ready")
  cacheKey        String?            @unique
  questions       QuizQuestion[]
  sourceDocuments SourceDocument[]
  generationCache GeneratedQuizCache?
  results         Result[]
  questionAttempts QuestionAttempt[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([subjectId])
  @@map("quizzes")
}

model Result {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId         String
  quiz           Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  score          Int
  correctAnswers Int
  totalQuestions Int
  completedAt    DateTime @default(now())
  questionAttempts QuestionAttempt[]

  @@index([userId])
  @@index([userId, completedAt])
  @@index([quizId])
  @@map("results")
}

model SourceDocument {
  id          String         @id @default(cuid())
  subjectId   String
  subject     Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  quizId      String
  quiz        Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  fileName    String
  mimeType    String
  checksum    String
  rawText     String
  chunkCount  Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  chunks      DocumentChunk[]

  @@index([subjectId])
  @@index([quizId])
  @@map("source_documents")
}

model DocumentChunk {
  id               String         @id @default(cuid())
  sourceDocumentId String
  sourceDocument   SourceDocument @relation(fields: [sourceDocumentId], references: [id], onDelete: Cascade)
  sequence         Int
  content          String
  tokenEstimate    Int            @default(0)
  embedding        Json
  createdAt        DateTime       @default(now())

  @@index([sourceDocumentId, sequence])
  @@map("document_chunks")
}

model QuizQuestion {
  id          String   @id @default(cuid())
  quizId      String
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  position    Int
  type        String
  difficulty  String
  topic       String?
  prompt      String
  options     Json?
  answer      Json
  explanation String?
  createdAt   DateTime @default(now())
  attempts    QuestionAttempt[]

  @@unique([quizId, position])
  @@index([type])
  @@index([topic])
  @@map("quiz_questions")
}

model GeneratedQuizCache {
  id             String   @id @default(cuid())
  cacheKey       String   @unique
  subjectId      String
  subject        Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  quizId         String?  @unique
  quiz           Quiz?    @relation(fields: [quizId], references: [id], onDelete: SetNull)
  sourceChecksum String
  model          String
  difficulty     String
  questionCount  Int
  questionTypes  Json
  responseJson   Json
  createdAt      DateTime @default(now())
  expiresAt      DateTime

  @@index([subjectId])
  @@index([expiresAt])
  @@map("generated_quiz_cache")
}

model QuestionAttempt {
  id           String       @id @default(cuid())
  resultId     String
  result       Result       @relation(fields: [resultId], references: [id], onDelete: Cascade)
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId       String
  quiz         Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  subjectId    String
  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  questionId   String
  question     QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  sessionOrder Int
  questionType String
  difficulty   String
  topic        String?
  isCorrect    Boolean?
  timeSpentMs  Int
  selectedOption Int?
  answerText   String?
  createdAt    DateTime     @default(now())

  @@index([resultId, sessionOrder])
  @@index([userId, createdAt])
  @@index([userId, subjectId, createdAt])
  @@index([userId, difficulty, createdAt])
  @@index([userId, questionType, createdAt])
  @@index([userId, topic, createdAt])
  @@index([quizId])
  @@index([questionId])
  @@map("question_attempts")
}
