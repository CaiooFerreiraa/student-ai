{
  "name": "@student-ai/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --bun next dev",
    "build": "bun run --bun next build",
    "start": "bun run --bun next start",
    "lint": "eslint .",
    "test": "node ./node_modules/jest/bin/jest.js --runInBand --coverage",
    "test:watch": "node ./node_modules/jest/bin/jest.js --watch",
    "test:e2e": "node ./node_modules/@playwright/test/cli.js test",
    "test:load": "k6 run tests/k6/rate-limit.js",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "bunx --bun prisma generate --config prisma.config.ts",
    "prisma:migrate:dev": "bunx --bun prisma migrate dev --config prisma.config.ts",
    "postinstall": "bun run prisma:generate"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@langchain/openai": "^0.6.16",
    "@langchain/textsplitters": "^0.1.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@sentry/nextjs": "^10.48.0",
    "@tanstack/react-query": "^5.90.5",
    "@upstash/ratelimit": "^2.0.7",
    "@upstash/redis": "^1.35.6",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^3.0.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.542.0",
    "next": "16.2.1",
    "next-auth": "beta",
    "pdf-parse": "^1.1.1",
    "pg": "^8.16.3",
    "prisma": "^7.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.62.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.1.13",
    "@types/bcryptjs": "^3.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.2",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitest/coverage-v8": "^4.1.4",
    "bun-types": "^1.3.5",
    "eslint": "^9.38.0",
    "eslint-config-next": "16.2.1",
    "jest": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  }
}
